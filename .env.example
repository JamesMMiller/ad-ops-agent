# Copy this file to .env (never commit .env).
# Values with special characters ({, [, *, etc.) MUST be single-quoted.

# ── Backend ──────────────────────────────────────────────────────────────────
# kie  = KIE.ai (default)
# none = workspace / local skills only
AD_OPS_BACKEND=kie

# ── KIE.ai ───────────────────────────────────────────────────────────────────
# https://kie.ai/api-key
# Sent as: Authorization: Bearer $KIE_API_KEY
KIE_API_KEY=your_key_here

# Optional — override if KIE directs your workspace to a different host.
# KIE_BASE_URL=https://api.kie.ai

# ── Meta Ads (meta-ad-builder — OPTIONAL) ────────────────────────────────────
# Publishing creatives as Meta ads. Every ad is created PAUSED.
# META_ACCESS_TOKEN=your_long_lived_token_here
# META_AD_ACCOUNT_ID=act_1234567890
# META_PAGE_ID=
# META_IG_USER_ID=
# META_PIXEL_ID=
# META_API_VERSION=v23.0

# ── Shopify (shopify-store — OPTIONAL) ───────────────────────────────────────
# Dev Dashboard app credentials (client credentials grant → 24h Admin token).
# https://shopify.dev/docs/apps/build/dev-dashboard/get-api-access-tokens
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here
SHOPIFY_API_VERSION=2025-10
# Optional — theme file push when Admin themeFilesUpsert is blocked:
# SHOPIFY_THEME_ID=
# SHOPIFY_THEME_ACCESS_PASSWORD=
